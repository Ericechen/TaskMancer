{
  "productName": "TaskMancer",
  "version": "1.0.0",
  "identifier": "com.taskmancer.app",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "TaskMancer",
        "label": "main",
        "width": 1280,
        "height": 800,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/app-icon.png"
    ]
  },
  "plugins": {
    "shell": {
      "allow": [
        {
          "name": "start-bat",
          "cmd": "cmd",
          "args": ["/c", "start.bat"],
          "cwd": ".."
        },
        {
          "name": "stop-bat",
          "cmd": "cmd",
          "args": ["/c", "StopTaskMancer.bat"],
          "cwd": ".."
        }
      ]
    }
  }
}
